<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="reporte_reservas" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30">

    <field name="id" class="java.lang.Long"/>
    <field name="usuarioNombre" class="java.lang.String"/>
    <field name="usuarioEmail" class="java.lang.String"/>
    <field name="perfumeNombre" class="java.lang.String"/>
    <field name="perfumeMarca" class="java.lang.String"/>
    <field name="fechaReserva" class="java.lang.String"/>
    <field name="estado" class="java.lang.String"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="535" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[Reporte de Reservas]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[Tu Aroma Encantador]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="30" height="30" backcolor="#7C3AED" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="30" y="0" width="110" height="30" backcolor="#7C3AED" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Usuario]]></text>
            </staticText>
            <staticText>
                <reportElement x="140" y="0" width="130" height="30" backcolor="#7C3AED" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Email]]></text>
            </staticText>
            <staticText>
                <reportElement x="270" y="0" width="100" height="30" backcolor="#7C3AED" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Perfume]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="80" height="30" backcolor="#7C3AED" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>
            <staticText>
                <reportElement x="450" y="0" width="85" height="30" backcolor="#7C3AED" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Estado]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25">
            <textField>
                <reportElement x="0" y="0" width="30" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="30" y="0" width="110" height="25"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{usuarioNombre}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="0" width="130" height="25"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{usuarioEmail}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="270" y="0" width="100" height="25"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{perfumeNombre}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="370" y="0" width="80" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{fechaReserva}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="450" y="0" width="85" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{estado}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="535" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>